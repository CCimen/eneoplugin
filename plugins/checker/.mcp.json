{
  "mcpServers": {
    "checker": {
      "command": "uv",
      "args": [
        "run",
        "--no-sync",
        "--with",
        "fastmcp<3",
        "python",
        "${CLAUDE_PLUGIN_ROOT}/mcp/typecheck_server.py"
      ],
      "env": {
        "PYTHONUNBUFFERED": "1"
      }
    }
  }
}
